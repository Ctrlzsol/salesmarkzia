# ── Required ────────────────────────────────────────────────────────
# Postgres connection string. On Replit this is provisioned automatically
# and injected as DATABASE_URL.
DATABASE_URL="postgres://user:password@host:5432/dbname"

# Password that protects the /admin dashboard (admin login).
ADMIN_PASSWORD="choose-a-strong-password"

# Secret used to sign the admin session cookie. Use a long random string.
SESSION_SECRET="generate-a-long-random-string"

# ── Optional ────────────────────────────────────────────────────────
# Gemini API key for AI recommendations. If unset, the app falls back to
# the local rules engine (no AI calls).
GEMINI_API_KEY=""
